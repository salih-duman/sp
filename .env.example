NODE_ENV=development
HOST=127.0.0.1
PORT=3000
APP_BASE_URL=https://dev.duman.dev

DATABASE_URL=postgres://app_user:change_me@localhost:5432/app_db
DATABASE_SSL=false

REDIS_URL=redis://localhost:6379

QUEUE_ENABLED=false
RABBITMQ_URL=amqp://app_user:change_me@localhost:5672
RABBITMQ_EXCHANGE=app.events
RABBITMQ_USER_REGISTERED_QUEUE=user.registered

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=12

REGISTRATION_ENABLED=true
REQUIRE_HTTPS=false
TRUST_PROXY=1
